// Prisma schema - Sistema de pedidos de empanadas
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CLIENTE
  ADMIN
}

enum OrderStatus {
  ENVIADO     // pedido enviado
  EN_CAMINO   // en camino
  ENTREGADO   // entregado
  CANCELADO
}

model User {
  id        String    @id @default(uuid())
  cedula    String    @unique          // unica, validada con formato dominicano
  password  String                     // hash bcrypt
  nombre    String
  telefono  String
  role      Role      @default(CLIENTE)
  addresses Address[]
  orders    Order[]
  createdAt DateTime  @default(now())
}

model Address {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  etiqueta  String   // "Casa", "Trabajo"
  direccion String
  lat       Float?
  lng       Float?
  activa    Boolean  @default(true) // soft delete: false = oculta de la lista
  createdAt DateTime @default(now())
  orders    Order[]
}

model Product {
  id          String      @id @default(uuid())
  nombre      String
  descripcion String
  imagen      String
  precio      Decimal     @db.Decimal(10, 2)
  activo      Boolean     @default(true)
  items       OrderItem[]
  createdAt   DateTime    @default(now())
}

model Delivery {
  id        String   @id @default(uuid())
  nombre    String
  telefono  String   // para wa.me
  activo    Boolean  @default(true)
  orders    Order[]
}

model Order {
  id         String      @id @default(uuid())
  numero     String      @unique         // PED-000001
  user       User        @relation(fields: [userId], references: [id])
  userId     String
  address    Address     @relation(fields: [addressId], references: [id])
  addressId  String
  delivery   Delivery?   @relation(fields: [deliveryId], references: [id])
  deliveryId String?
  status     OrderStatus @default(ENVIADO)
  nota       String?
  total      Decimal     @db.Decimal(10, 2)
  items      OrderItem[]
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
}

model OrderItem {
  id         String  @id @default(uuid())
  order      Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId    String
  product    Product @relation(fields: [productId], references: [id])
  productId  String
  cantidad   Int
  precioUnit Decimal @db.Decimal(10, 2) // snapshot del precio al momento del pedido
}

model BusinessConfig {
  id           Int     @id @default(1)        // fila unica
  horaApertura String  @default("09:00")      // formato HH:mm
  horaCierre   String  @default("22:00")
  abierto      Boolean @default(true)          // override manual
}
