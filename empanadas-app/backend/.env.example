# Base de datos PostgreSQL
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/empanadas?schema=public"

# Secreto JWT (cambia esto por una cadena larga y aleatoria en produccion)
JWT_SECRET="cambia-esto-por-algo-muy-largo-y-aleatorio-32-chars-min"

# Puerto del backend
PORT=4000

# URL del frontend (para CORS y Socket.IO)
FRONTEND_URL="http://localhost:3000"
